# LeadChain MCP Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration
# ============================================================================
POSTGRES_USER=leadchain_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=leadchain_db
POSTGRES_PORT=5432

# Full connection URL (for local development without Docker)
DATABASE_URL=postgresql://leadchain_user:your_secure_password_here@localhost:5432/leadchain_db

# ============================================================================
# Meta (Facebook/Instagram) Configuration
# ============================================================================

# App Secret - used to verify webhook signatures
# Find at: https://developers.facebook.com/apps/{app-id}/settings/basic/
META_APP_SECRET=your_meta_app_secret

# Access Token - used to fetch lead data from Graph API
# Generate a Page Access Token with leads_retrieval permission
# https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_meta_access_token

# Verify Token - custom string for webhook verification
# Set this to any secure random string, then use same value in Meta webhook config
META_VERIFY_TOKEN=leadchain_verify_token

# Graph API Version (optional)
META_GRAPH_API_VERSION=v18.0

# ============================================================================
# Zoho CRM Configuration
# ============================================================================

# OAuth credentials from Zoho API Console
# https://api-console.zoho.com/
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret

# Refresh Token - generate using Zoho OAuth flow
# Required scopes: ZohoCRM.modules.leads.ALL
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# API Domain (varies by data center)
# US: https://www.zohoapis.com
# EU: https://www.zohoapis.eu
# IN: https://www.zohoapis.in
# AU: https://www.zohoapis.com.au
# CN: https://www.zohoapis.com.cn
ZOHO_API_DOMAIN=https://www.zohoapis.com

# Accounts Domain (for OAuth token refresh)
# US: https://accounts.zoho.com
# EU: https://accounts.zoho.eu
# IN: https://accounts.zoho.in
# AU: https://accounts.zoho.com.au
# CN: https://accounts.zoho.com.cn
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com

# ============================================================================
# Sync Worker Configuration
# ============================================================================

# Sync interval in milliseconds (default: 5 minutes)
SYNC_INTERVAL_MS=300000

# Number of leads to process per batch
SYNC_BATCH_SIZE=50

# Maximum retry attempts before abandoning a lead
SYNC_MAX_RETRIES=5

# Delay between API calls to respect rate limits (ms)
SYNC_RATE_LIMIT_DELAY_MS=200

# Extra delay after errors (ms)
SYNC_ERROR_DELAY_MS=5000

# ============================================================================
# Server Configuration
# ============================================================================

# Environment
NODE_ENV=production

# Webhook server port
WEBHOOK_PORT=3000

# Host to bind to (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# ============================================================================
# Redis Configuration (optional, for future features)
# ============================================================================
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
